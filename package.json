{
  "name": "nx-run",
  "version": "1.0.2",
  "description": "Fuzzy-search Nx task runner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KacperKozak/nx-run"
  },
  "type": "module",
  "bin": {
    "nxr": "bin/nxr.js"
  },
