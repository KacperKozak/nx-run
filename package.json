    "publish-all": "bun scripts/publish.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "latest",
    "fuse.js": "^7",
    "ink": "^5",
    "ink-text-input": "^6",
    "react": "^18",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "@nx-run/darwin-arm64": "1.0.2",
    "@nx-run/darwin-x64": "1.0.2",
    "@nx-run/linux-x64": "1.0.2",
    "@nx-run/linux-arm64": "1.0.2",
    "@nx-run/win32-x64": "1.0.2"
  }
}
